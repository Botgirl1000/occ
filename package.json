{
  "name": "@cesarandreslopez/occ",
  "version": "0.6.1",
  "description": "Office Cloc and Count — scc-style summary tables for office documents",
  "type": "module",
  "bin": {
    "occ": "./dist/bin/occ.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Cesar Andres Lopez <cesarandreslopez@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cesarandreslopez/occ.git"
  },
  "homepage": "https://github.com/cesarandreslopez/occ",
  "bugs": {
    "url": "https://github.com/cesarandreslopez/occ/issues"
  },
  "keywords": [
    "office",
    "documents",
    "cloc",
    "count",
    "metrics",
    "docx",
    "xlsx",
    "pptx",
    "pdf",
    "scc",
    "cli",
    "confidence"
  ],
  "exports": {
    ".": {
      "types": "./dist/bin/occ.d.ts",
      "default": "./dist/bin/occ.js"
    },
    "./code/build": {
      "types": "./dist/src/code/build.d.ts",
      "default": "./dist/src/code/build.js"
    },
    "./code/types": {
      "types": "./dist/src/code/types.d.ts",
      "default": "./dist/src/code/types.js"
    },
    "./code/query": {
      "types": "./dist/src/code/query.d.ts",
      "default": "./dist/src/code/query.js"
    },
    "./code/discover": {
      "types": "./dist/src/code/discover.d.ts",
      "default": "./dist/src/code/discover.js"
    },
    "./code/chunk": {
      "types": "./dist/src/code/chunk.d.ts",
      "default": "./dist/src/code/chunk.js"
    },
    "./code/cache": {
      "types": "./dist/src/code/cache.d.ts",
      "default": "./dist/src/code/cache.js"
    },
    "./doc/inspect": {
      "types": "./dist/src/doc/inspect.d.ts",
      "default": "./dist/src/doc/inspect.js"
    },
    "./doc/types": {
      "types": "./dist/src/doc/types.d.ts",
      "default": "./dist/src/doc/types.js"
    },
    "./doc/discover": {
      "types": "./dist/src/doc/discover.d.ts",
      "default": "./dist/src/doc/discover.js"
    },
    "./doc/batch": {
      "types": "./dist/src/doc/batch.d.ts",
      "default": "./dist/src/doc/batch.js"
    },
    "./markdown/convert": {
      "types": "./dist/src/markdown/convert.d.ts",
      "default": "./dist/src/markdown/convert.js"
    },
    "./structure/extract": {
      "types": "./dist/src/structure/extract.d.ts",
      "default": "./dist/src/structure/extract.js"
    },
    "./structure/types": {
      "types": "./dist/src/structure/types.d.ts",
      "default": "./dist/src/structure/types.js"
    },
    "./sheet/inspect": {
      "types": "./dist/src/sheet/inspect.d.ts",
      "default": "./dist/src/sheet/inspect.js"
    },
    "./sheet/types": {
      "types": "./dist/src/sheet/types.d.ts",
      "default": "./dist/src/sheet/types.js"
    },
    "./slide/inspect": {
      "types": "./dist/src/slide/inspect.d.ts",
      "default": "./dist/src/slide/inspect.js"
    },
    "./table/inspect": {
      "types": "./dist/src/table/inspect.d.ts",
      "default": "./dist/src/table/inspect.js"
    },
    "./tokens": {
      "types": "./dist/src/tokens.d.ts",
      "default": "./dist/src/tokens.js"
    },
    "./doc/entities": {
      "types": "./dist/src/doc/entities.d.ts",
      "default": "./dist/src/doc/entities.js"
    },
    "./doc/references": {
      "types": "./dist/src/doc/references.d.ts",
      "default": "./dist/src/doc/references.js"
    },
    "./progress-event": {
      "types": "./dist/src/progress-event.d.ts",
      "default": "./dist/src/progress-event.js"
    },
    "./types": {
      "types": "./dist/src/types.d.ts",
      "default": "./dist/src/types.js"
    },
    "./stats": {
      "types": "./dist/src/stats.d.ts",
      "default": "./dist/src/stats.js"
    }
  },
  "files": [
    "dist/",
    "scripts/postinstall.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/occ.ts",
    "start": "node dist/bin/occ.js",
    "test": "npm run build && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "officeparser": "^6.0.1",
    "pdf-parse": "^1.1.1",
    "turndown": "^7.2.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/turndown": "^5.0.6",
    "docx": "^9.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
